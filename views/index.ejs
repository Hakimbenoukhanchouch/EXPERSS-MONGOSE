<head>
  <meta charset="UTF-8">
  <title>CRUD Produits</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>


<body class="bg-light">

<div class="container mt-5">
  <h2 class="text-center mb-4">📦 Liste des Produits</h2>

  <div class="text-end mb-3">
    <a href="/add" class="btn btn-success">➕ Ajouter Produit</a>
  </div>

  <table class="table table-bordered table-hover text-center shadow">
    <thead class="table-dark">
      <tr>
        <th>Nom</th>
        <th>Prix</th>
        <th>Quantité</th>
        <th>Actions</th>
      </tr>
    </thead>

    <tbody>
      <% produits.forEach(p => { %>
        <tr>
          <td><%= p.name %></td>
          <td><%= p.price %> DH</td>
          <td><%= p.quantity %></td>
          <td>
            <a href="/edit/<%= p._id %>" class="btn btn-warning btn-sm">✏️ Modifier</a>

            <form action="/delete/<%= p._id %>?_method=DELETE" method="POST" style="display:inline;">
              <button class="btn btn-danger btn-sm">🗑 Supprimer</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

</body>